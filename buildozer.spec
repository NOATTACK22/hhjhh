[app]
title = Supreme Terminal V16
package.name = supremev16
package.domain = org.noattack
source.dir = .
source.include_exts = py,png,jpg,kv,atlas,json
version = 1.0
requirements = python3,kivy==2.2.1,kivymd==1.1.1,PyGithub,requests,certifi,urllib3,idna,charset-normalizer
orientation = portrait
osx.python_version = 3
osx.kivy_version = 1.9.1
fullscreen = 0
android.permissions = INTERNET, ACCESS_NETWORK_STATE
android.archs = arm64-v8a, armeabi-v7a
android.allow_backup = True
ios.kivy_version = 1.10.1
